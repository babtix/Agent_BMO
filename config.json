{
  "groq": {
    "api_key_env": "GROQ_API_KEY",
    "primary_model": "whisper-large-v3",
    "fallback_model": "whisper-large-v3-turbo",
    "language": "en"
  },
  "ollama": {
    "model": "qwen3-coder:480b-cloud",
    "host": "http://localhost:11434",
    "stream": true,
    "temperature": 0.7,
    "context_window": 4096
  },
  "language": {
    "code": "en",
    "name": "English",
    "supported": [
      "en",
      "fr",
      "es",
      "de",
      "it",
      "pt",
      "ar",
      "ja",
      "zh",
      "ru",
      "nl",
      "pl",
      "tr",
      "ko",
      "hi"
    ]
  },
  "wake_word": {
    "enabled": true,
    "word": "hi",
    "alternatives": [
      "hi",
      "hii",
      "hie",
      "bmo",
      "assistant",
      "bmo",
      "haka"
    ],
    "sensitivity": 0.5,
    "wake_word_listen_duration": 3
  },
  "audio": {
    "sample_rate": 16000,
    "channels": 1,
    "vad_enabled": true,
    "silence_threshold": 0.01,
    "silence_duration": 1.5,
    "max_recording_duration": 30,
    "command_listen_duration": 10
  },
  "tts": {
    "engine": "pyttsx3",
    "engines_available": [
      "pyttsx3",
      "gtts",
      "edge"
    ],
    "speed": "normal",
    "voice": "default",
    "streaming": false,
    "chunk_size": 50
  },
  "conversation": {
    "max_history": 10,
    "save_sessions": true,
    "session_dir": "sessions",
    "system_prompt": "You are HAKA, a helpful voice assistant. Keep responses concise and natural for voice interaction."
  },
  "ui": {
    "theme": "dark",
    "window_width": 1050,
    "window_height": 720
  },
  "performance": {
    "log_metrics": true,
    "show_latency": true
  }
}